    {
      "parameters": {
        "promptType": "define",
        "text": "=Job Title: {{ $json.title }}\nCompany Name:{{ $json.companyName }}\nEmployment Type: {{ $json.employmentType }}\n\nJob Description:\n{{ $json.descriptionText }}\n\nCompany Description:\n{{ $json.companyDescription }}\n\nPlease write a professional, tailored cover letter for this job vacancy.",
        "options": {
          "systemMessage": "You are a professional career coach and expert cover letter writer.\n\nWrite a tailored, compelling cover letter based on the provided job details.\n\nRequirements:\n- Include a clear subject line\n- Use a professional business letter format\n- Personalize it to the job title and company\n- Highlight relevant skills and value\n- Keep it concise (300–400 words)\n- Use a confident and professional tone"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
